    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.1.0",
    "tsx": "^4.20.3",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
